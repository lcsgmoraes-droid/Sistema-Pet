# Variaveis de ambiente do App Mobile (Expo)
# Copie este arquivo como .env e preencha os valores reais.
# Nao subir .env para o Git.

# API usada pelo app.
# Em desenvolvimento com celular fisico, use o IP da sua maquina:
# EXPO_PUBLIC_API_URL=http://192.168.0.10:8000/api
# Se deixar vazio, o app usa http://localhost:8000/api em dev e producao em release.
EXPO_PUBLIC_API_URL=

# Overrides opcionais por ambiente.
EXPO_PUBLIC_DEV_API_URL=http://localhost:8000/api
EXPO_PUBLIC_PROD_API_URL=https://mlprohub.com.br/api

# UUID do tenant do PetShop.
# Como encontrar: faca login no sistema web como admin
# e veja em Configuracoes > Sobre > ID da Loja.
EXPO_PUBLIC_TENANT_ID=SEU_TENANT_UUID_AQUI
