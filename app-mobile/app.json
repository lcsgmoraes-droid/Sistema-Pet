{
  "expo": {
    "name": "CorePet",
    "slug": "petshop-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/158693e8-177c-4be6-8e2f-143d0d8260dd"
    },
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F5F66"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.petshoppro.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Usado para escanear codigo de barras dos produtos.",
        "NSPhotoLibraryUsageDescription": "Usado para adicionar foto do seu pet.",
        "NSLocationWhenInUseUsageDescription": "Usado para sugerir a loja mais proxima e enviar a posicao do entregador durante rotas ativas."
      },
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F5F66"
      },
      "package": "com.petshoppro.app",
      "permissions": [
        "POST_NOTIFICATIONS",
        "READ_MEDIA_IMAGES",
        "VIBRATE"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "runtimeVersion": "1.0.0"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Permite escanear codigos de barras dos produtos.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C9A13A",
          "sounds": []
        }
      ],
      [
        "expo-secure-store"
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Usado para sugerir a loja mais proxima e enviar a posicao do entregador durante rotas ativas."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Usado para adicionar foto do seu pet."
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "158693e8-177c-4be6-8e2f-143d0d8260dd"
      }
    },
    "owner": "petshop"
  }
}
