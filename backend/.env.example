# ====================
# SISTEMA
# ====================
SYSTEM_NAME=Pet Shop Pro
ENVIRONMENT=development
# development ou production

# ====================
# SEGURANÇA
# ====================
JWT_SECRET_KEY=change-this-to-a-random-secure-key-in-production
ADMIN_TOKEN=change-this-admin-token
# Gerar chave de criptografia: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ====================
# BANCO DE DADOS
# ====================
# ⚠️ PRODUÇÃO USA POSTGRESQL
DATABASE_TYPE=postgresql

# SQLite SOMENTE para testes locais isolados
# DATABASE_TYPE=sqlite
# SQLITE_DB_PATH=petshop.db

# PostgreSQL (para produção ou Docker)
# ⚠️ IMPORTANTE: Ao usar Docker, use o nome do serviço (ex: "postgres") ao invés de "localhost"
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=petshop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ====================
# EMAIL (SMTP)
# ====================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@petshop.com

# ====================
# INTEGRAÇÕES
# ====================

# Bling (E-commerce)
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
BLING_ACCESS_TOKEN=
BLING_REFRESH_TOKEN=
# Tenant dono dos webhooks Bling sem JWT; tambem usado pela observabilidade Ops.
BLING_WEBHOOK_TENANT_ID=
OPS_BACKFILL_TENANT_ID=
BLING_SYNC_SCHEDULER_ENABLED=false
BLING_WORKER_SQLALCHEMY_POOL_SIZE=3
BLING_WORKER_SQLALCHEMY_MAX_OVERFLOW=4
BLING_PEDIDO_WEBHOOK_ASYNC=true
BLING_PEDIDO_WEBHOOK_QUEUE_INTERVAL_SECONDS=5
BLING_PEDIDO_WEBHOOK_QUEUE_LIMIT=20
BLING_PEDIDO_WEBHOOK_MAX_ATTEMPTS=6
BLING_PEDIDO_WEBHOOK_FALLBACK_SYNC=true

# WhatsApp Business API
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Firebase (Push Notifications)
FIREBASE_SERVER_KEY=
FIREBASE_PROJECT_ID=

# IA / LLM
OPENAI_API_KEY=
GROQ_API_KEY=
GOOGLE_AI_API_KEY=

# WhatsApp Orchestrator (WAHA/n8n -> backend internal endpoint)
WHATSAPP_ORCHESTRATOR_INTERNAL_TOKEN=

# SEFAZ (NF-e)
# Modo inicial recomendado: mock (simulado)
# Para integração real: SEFAZ_ENABLED=true e SEFAZ_MODO=real
SEFAZ_ENABLED=false
SEFAZ_MODO=mock
SEFAZ_AMBIENTE=homologacao
SEFAZ_UF=
SEFAZ_CNPJ=
SEFAZ_CERT_PATH=
SEFAZ_CERT_PASSWORD=
SEFAZ_TIMEOUT_SECONDS=30
SEFAZ_IMPORTACAO_AUTOMATICA=false
SEFAZ_IMPORTACAO_INTERVALO_MIN=15
SEFAZ_ULTIMO_NSU=000000000000000

# Google Maps (Rotas e Entregas)
# Obtenha em: https://console.cloud.google.com/
# APIs necessárias: Maps JavaScript API, Directions API, Distance Matrix API
GOOGLE_MAPS_API_KEY=

# ====================
# FRONTEND
# ====================
FRONTEND_URL=http://localhost:5173

# ====================
# UPLOADS
# ====================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
