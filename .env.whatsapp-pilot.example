# Piloto WhatsApp (WAHA + n8n)
# Copie para .env.whatsapp-pilot e preencha os valores

# WAHA
WAHA_API_KEY=trocar_este_token
WAHA_PRINT_QR=true
WAHA_BASE_URL=http://waha:3000

# n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=trocar_senha_forte
N8N_ENCRYPTION_KEY=trocar_chave_longa_e_aleatoria
GENERIC_TIMEZONE=America/Sao_Paulo

# Backend internal ingest
# Em Docker Desktop no Windows, host.docker.internal acessa o backend rodando no host
BACKEND_INTERNAL_BASE_URL=http://host.docker.internal:8000
BACKEND_TENANT_ID=preencher_tenant_id_real
BACKEND_INTERNAL_TOKEN=trocar_token_interno
