#!/bin/sh

if [ "$ALLOW_MAIN_PUSH" = "1" ]; then
  exit 0
fi

blocked=0

while read local_ref local_sha remote_ref remote_sha
do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master)
      blocked=1
      ;;
  esac
done

if [ "$blocked" -eq 1 ]; then
  echo "BLOQUEADO: push direto para main/master."
  echo "Use uma branch de tarefa e abra Pull Request no GitHub."
  echo "Para emergencia autorizada: defina ALLOW_MAIN_PUSH=1 apenas naquele comando."
  exit 1
fi

exit 0
